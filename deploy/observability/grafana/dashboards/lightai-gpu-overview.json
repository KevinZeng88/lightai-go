{
  "title": "LightAI GPU 资源总览",
  "uid": "lightai-gpu-overview",
  "panels": [
    {"title":"Server Up","type":"stat","gridPos":{"x":0,"y":0,"w":4,"h":3},"targets":[{"expr":"lightai_server_info","legendFormat":"server"}]},
    {"title":"GPU Count","type":"stat","gridPos":{"x":4,"y":0,"w":4,"h":3},"targets":[{"expr":"lightai_server_gpus_total","legendFormat":"total"}],"fieldConfig":{"defaults":{"thresholds":{"steps":[{"color":"red","value":0},{"color":"green","value":1}]}}}},
    {"title":"GPU Utilization","type":"timeseries","gridPos":{"x":8,"y":0,"w":8,"h":7},"targets":[{"expr":"lightai_gpu_utilization_percent","legendFormat":"{{gpu_name}} ({{gpu_index}})"}],"fieldConfig":{"defaults":{"unit":"percent","min":0,"max":100}}},
    {"title":"GPU Memory Used","type":"bargauge","gridPos":{"x":16,"y":0,"w":8,"h":7},"targets":[{"expr":"lightai_gpu_memory_used_bytes / (1024*1024*1024)","legendFormat":"{{gpu_name}}"}],"fieldConfig":{"defaults":{"unit":"decgbytes"}}},
    {"title":"GPU Memory Utilization","type":"timeseries","gridPos":{"x":0,"y":7,"w":8,"h":6},"targets":[{"expr":"lightai_gpu_memory_utilization_percent","legendFormat":"{{gpu_name}}"}],"fieldConfig":{"defaults":{"unit":"percent"}}},
    {"title":"GPU Temperature","type":"timeseries","gridPos":{"x":8,"y":7,"w":8,"h":6},"targets":[{"expr":"lightai_gpu_temperature_celsius","legendFormat":"{{gpu_name}}"}],"fieldConfig":{"defaults":{"unit":"celsius"}}},
    {"title":"GPU Power","type":"timeseries","gridPos":{"x":16,"y":7,"w":8,"h":6},"targets":[{"expr":"lightai_gpu_power_draw_watts","legendFormat":"{{gpu_name}}"}],"fieldConfig":{"defaults":{"unit":"watt"}}},
    {"title":"GPU Health","type":"table","gridPos":{"x":0,"y":13,"w":12,"h":5},"targets":[{"expr":"lightai_gpu_health_status","legendFormat":"{{gpu_name}}"}],"fieldConfig":{"defaults":{"mappings":[{"type":"value","value":"1","text":"健康"},{"type":"value","value":"0","text":"异常"}]}}},
    {"title":"GPU Memory Total","type":"table","gridPos":{"x":12,"y":13,"w":12,"h":5},"targets":[{"expr":"lightai_gpu_memory_total_bytes / (1024*1024*1024)","legendFormat":"{{gpu_name}}"}],"fieldConfig":{"defaults":{"unit":"decgbytes"}}}
  ],
  "schemaVersion": 36,
  "tags": ["lightai","gpu"],
  "refresh": "10s"
}
