        "x": 12,
        "y": 0,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "expr": "lightai_host_load1",
          "legendFormat": "1分钟"
        },
        {
          "expr": "lightai_host_load5",
          "legendFormat": "5分钟"
        },
        {
          "expr": "lightai_host_load15",
          "legendFormat": "15分钟"
        }
      ]
    },
