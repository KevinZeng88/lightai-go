{
  "title": "LightAI 主机资源",
  "uid": "lightai-host-resources",
  "panels": [
    {
      "title": "CPU 使用率",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "expr": "lightai_host_cpu_usage_ratio * 100",
          "legendFormat": "CPU %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "title": "系统负载",
