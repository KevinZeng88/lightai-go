{
  "title": "LightAI 主机资源",
  "uid": "lightai-host-resources",
  "panels": [
    {
      "title": "CPU 使用率",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 8, "h": 6},
      "targets": [{"expr": "lightai_host_cpu_usage_ratio * 100", "legendFormat": "CPU"}],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}}
    },
    {
      "title": "系统负载",
      "type": "timeseries",
      "gridPos": {"x": 8, "y": 0, "w": 8, "h": 6},
      "targets": [
        {"expr": "lightai_host_load1", "legendFormat": "1分钟"},
        {"expr": "lightai_host_load5", "legendFormat": "5分钟"},
        {"expr": "lightai_host_load15", "legendFormat": "15分钟"}
      ]
    },
    {
      "title": "内存使用率",
      "type": "gauge",
      "gridPos": {"x": 16, "y": 0, "w": 8, "h": 6},
      "targets": [{"expr": "max(lightai_host_memory_used_ratio) * 100", "legendFormat": "内存"}],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}}
    },
    {
      "title": "内存使用",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 6, "w": 12, "h": 5},
      "targets": [{"expr": "lightai_host_memory_used_bytes / (1024*1024*1024)", "legendFormat": "已用 GB"}],
      "fieldConfig": {"defaults": {"unit": "decgbytes"}}
    },
    {
      "title": "文件系统使用率",
      "type": "gauge",
      "gridPos": {"x": 12, "y": 6, "w": 6, "h": 5},
      "targets": [{"expr": "max(lightai_host_filesystem_used_ratio{mountpoint=\"/\"}) * 100", "legendFormat": "{{mountpoint}}"}],
      "fieldConfig": {"defaults": {"unit": "percent"}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}}
    },
    {
      "title": "磁盘使用",
      "type": "table",
      "gridPos": {"x": 18, "y": 6, "w": 6, "h": 5},
      "targets": [
        {"expr": "lightai_host_filesystem_total_bytes / (1024*1024*1024)", "legendFormat": "{{mountpoint}} 总量 GB"},
        {"expr": "lightai_host_filesystem_used_bytes / (1024*1024*1024)", "legendFormat": "{{mountpoint}} 已用 GB"}
      ],
      "fieldConfig": {"defaults": {"unit": "decgbytes"}}
    },
    {
      "title": "主机信息",
      "type": "stat",
      "gridPos": {"x": 0, "y": 11, "w": 6, "h": 3},
      "targets": [{"expr": "lightai_host_cpu_cores", "legendFormat": "CPU 核数"}],
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}}
    }
  ],
  "schemaVersion": 36,
  "tags": ["lightai", "host"],
  "refresh": "10s"
}
