# LightAI Go - Grafana Admin Credentials TEMPLATE
# This file is a DEPLOYMENT TEMPLATE only. The values here are NOT used at runtime.
#
# To set Grafana admin credentials, use environment variables:
#   export LIGHTAI_GRAFANA_ADMIN_USER=admin
#   export LIGHTAI_GRAFANA_ADMIN_PASSWORD=<your-secure-password>
#
# If no password is provided, start-observability.sh generates a random one
# and persists it to runtime/observability/grafana.credentials.
#
# DO NOT put real passwords in this file — it is shipped in release tarballs.

# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=CHANGE_ME
